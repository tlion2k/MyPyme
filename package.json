{
  "name": "mypyme",
  "version": "1.0.0",
  "description": "Administrador de stock y ventas para pequeñas tiendas",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mypyme.app",
    "productName": "MyPyme",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/image/logo-ico.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
